//@version=5
strategy("Autoresearch Strategy", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100)

// ── Parameters ──
sma_fast = input.int(40, "sma_fast")
sma_slow = input.int(200, "sma_slow")
atr_period = input.int(10, "atr_period")
atr_mult = input.float(1.5, "atr_mult")

// ── Indicators ──
sma_sma_fast = ta.sma(close, sma_fast)
sma_sma_slow = ta.sma(close, sma_slow)
atr_val = ta.atr(atr_period)
atr_pct = atr_val / close
atr_pct_avg = ta.sma(atr_pct, 100)

// ── Entry/Exit Conditions ──
long_entry = sma_sma_fast > sma_sma_slow
long_exit = sma_sma_fast < sma_sma_slow

// ── Strategy Execution ──
if long_entry
    strategy.entry("Long", strategy.long)
if long_exit
    strategy.close("Long")

// ── Plots ──
plot(sma_sma_fast, "sma_fast", color.blue)
plot(sma_sma_slow, "sma_slow", color.orange)

bgcolor(long_entry ? color.new(color.green, 90) : na)